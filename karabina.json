{
  "description": "Ignore Ctrl+C, Ctrl+V, Ctrl+X",
  "manipulators": [
    {
      "conditions": [
        {
          "bundle_identifiers": [
            "^com\\.microsoft\\.VSCode$",
            "^com\\.microsoft\\.VSCodeInsiders$",
            "^com\\.github\\.wez\\.wezterm$"
          ],
          "type": "frontmost_application_unless"
        }
      ],
      "from": {
        "key_code": "c",
        "modifiers": {
          "mandatory": ["control"],
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "c",
          "modifiers": ["left_command"]
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": [
            "^com\\.microsoft\\.VSCode$",
            "^com\\.microsoft\\.VSCodeInsiders$",
            "^com\\.github\\.wez\\.wezterm$"
          ],
          "type": "frontmost_application_unless"
        }
      ],
      "from": {
        "key_code": "x",
        "modifiers": {
          "mandatory": ["control"],
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "x",
          "modifiers": ["left_command"]
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": [
            "^com\\.microsoft\\.VSCode$",
            "^com\\.microsoft\\.VSCodeInsiders$",
            "^com\\.github\\.wez\\.wezterm$"
          ],
          "type": "frontmost_application_unless"
        }
      ],
      "from": {
        "key_code": "v",
        "modifiers": {
          "mandatory": ["control"],
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "v",
          "modifiers": ["left_command"]
        }
      ],
      "type": "basic"
    }
  ]
}
